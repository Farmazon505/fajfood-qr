[Unit]
Description=QRnastol guest service
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/qrnastol
EnvironmentFile=/opt/qrnastol/.env
Environment=NODE_OPTIONS=--dns-result-order=ipv4first
ExecStart=/usr/bin/npm start
Restart=always
RestartSec=5
User=qrnastol
Group=qrnastol
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ReadWritePaths=/var/lib/qrnastol /opt/qrnastol

[Install]
WantedBy=multi-user.target
