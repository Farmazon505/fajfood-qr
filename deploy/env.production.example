NODE_ENV=production
HOST=127.0.0.1
PORT=4173
PUBLIC_BASE_URL=https://qr.crunchhaus.ru

ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-long-admin-password
OWNER_USERNAME=owner
OWNER_PASSWORD=replace-with-different-long-owner-password
ADMIN_SECRET=replace-with-random-32-plus-character-secret
ADMIN_TOKEN_TTL_HOURS=12
APP_DATA_DIR=/var/lib/qrnastol

TELEGRAM_BOT_TOKEN=replace-with-botfather-token
TELEGRAM_BOT_USERNAME=QROFFICBOT
TELEGRAM_ENABLE_POLLING=true
TRUST_PROXY=true
VENUE_TIME_ZONE=Europe/Astrakhan

# CRM loyalty API. Both apps currently run on the same server.
CRM_BASE_URL=http://127.0.0.1:3000
CRM_LOYALTY_SERVICE_SECRET=replace-with-the-same-random-secret-as-crm
LOYALTY_REGISTRATION_ALLOWLIST=+79990000000

# OpenRouter staff performance analysis. Never expose this key to the client.
AI_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=replace-with-openrouter-key
AI_MODEL=openai/gpt-4o-mini
AI_REQUEST_TIMEOUT_MS=12000
