NODE_ENV=production
HOST=127.0.0.1
PORT=4173
PUBLIC_BASE_URL=https://qr.crunchhaus.ru

ADMIN_PASSWORD=replace-with-long-password
ADMIN_SECRET=replace-with-random-32-plus-character-secret
ADMIN_TOKEN_TTL_HOURS=12
APP_DATA_DIR=/var/lib/qrnastol

TELEGRAM_BOT_TOKEN=replace-with-botfather-token
TELEGRAM_ENABLE_POLLING=true
TRUST_PROXY=true

# CRM loyalty API. Both apps currently run on the same server.
CRM_BASE_URL=http://127.0.0.1:3000
CRM_LOYALTY_SERVICE_SECRET=replace-with-the-same-random-secret-as-crm
LOYALTY_REGISTRATION_ALLOWLIST=+79990000000
