NODE_ENV=development
HOST=127.0.0.1
PORT=4173
PUBLIC_BASE_URL=http://localhost:5174

ADMIN_PASSWORD=change-me-please
ADMIN_SECRET=change-this-secret-to-a-long-random-value
ADMIN_TOKEN_TTL_HOURS=12
APP_DATA_DIR=./data

# Telegram BotFather token. When empty, calls are stored and logged only.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=QROFFICBOT

# Use polling locally if you cannot expose a webhook URL.
TELEGRAM_ENABLE_POLLING=false

# Set true when app is behind Nginx/Caddy/another proxy.
TRUST_PROXY=false

# CRM server-to-server loyalty integration. The secret must match
# CRM_LOYALTY_SERVICE_SECRET in CRM-Faj-v2 and contain 32+ characters.
CRM_BASE_URL=http://127.0.0.1:3000
CRM_LOYALTY_SERVICE_SECRET=replace-with-shared-random-32-plus-character-secret
CRM_STAFF_SERVICE_SECRET=replace-with-a-different-shared-random-32-plus-character-secret

# Optional comma-separated rollout guard. Leave empty only after phone OTP is enabled.
LOYALTY_REGISTRATION_ALLOWLIST=

# OpenRouter staff performance analysis. The key is server-only.
AI_BASE_URL=https://openrouter.ai/api/v1
AI_PROXY_URL=
OPENROUTER_API_KEY=
AI_MODEL=openai/gpt-4o-mini
AI_REQUEST_TIMEOUT_MS=12000
